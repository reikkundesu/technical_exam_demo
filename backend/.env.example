# All values must be set in .env; no hardcoded API keys, URLs, or credentials in code.
APP_NAME="Shopify Integration"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=shopify_integration
DB_USERNAME=root
DB_PASSWORD=

# Shopify App (from Partner Dashboard) - all required, no defaults
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
# e.g. read_products,write_products,read_orders,write_orders
SHOPIFY_SCOPES=
# e.g. 2024-01
SHOPIFY_API_VERSION=
SHOPIFY_WEBHOOK_SECRET=

# Internal API key for webhooks service and internal consumers (generate with: php artisan key:generate --show or openssl rand -hex 32)
INTERNAL_API_KEY=

# Webhooks service URL (used by Laravel to know where Shopify webhooks are received)
WEBHOOKS_SERVICE_URL=
